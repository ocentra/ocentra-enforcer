{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ocentra.dev/schemas/ocentra-enforcer/enforcer-config.schema.json",
  "title": "Ocentra Enforcer Config",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "schemaVersion": { "type": "number" },
    "profileName": { "type": "string" },
    "failFast": { "type": "boolean" },
    "enforceWorkspaceFiles": { "type": "boolean" },
    "requireCargoDeny": { "type": "boolean" },
    "requireCargoAudit": { "type": "boolean" },
    "runCargoDoc": { "type": "boolean" },
    "cargoOnFileScope": { "type": "boolean" },
    "cargoOnDiffScope": { "type": "boolean" },
    "cargoTestThreads": { "type": ["number", "null"] },
    "allowUnsafeCode": { "type": "boolean" },
    "allowBuildRs": { "type": "boolean" },
    "allowGitDependencies": { "type": "boolean" },
    "allowPathDependencies": { "type": "boolean" },
    "publicReexportPolicy": { "enum": ["forbid", "facade-only", "allow"] },
    "ignoreDirs": { "type": "array", "items": { "type": "string" } },
    "ignoreFileGlobs": { "type": "array", "items": { "type": "string" } },
    "rustRoots": { "type": "array", "items": { "type": "string" } },
    "crateRootGlobs": { "type": "array", "items": { "type": "string" } },
    "testFileGlobs": { "type": "array", "items": { "type": "string" } },
    "rawTypeBoundaryGlobs": { "type": "array", "items": { "type": "string" } },
    "facadeFileGlobs": { "type": "array", "items": { "type": "string" } },
    "rawStringOwnerGlobs": { "type": "array", "items": { "type": "string" } },
    "domainPrimitiveOwnerGlobs": { "type": "array", "items": { "type": "string" } },
    "enforceRuntimeStringLiterals": { "type": "boolean" },
    "runtimeStringOwnerGlobs": { "type": "array", "items": { "type": "string" } },
    "runtimeStringLineAllowPatterns": { "type": "array", "items": { "type": "string" } },
    "enforceSerializedPublicDomainPrimitives": { "type": "boolean" },
    "serializedDomainOwnerGlobs": { "type": "array", "items": { "type": "string" } },
    "blockedProtocolDependencies": {
      "type": "object",
      "additionalProperties": { "type": "array", "items": { "type": "string" } }
    },
    "runtimeCrates": { "type": "array", "items": { "type": "string" } },
    "testOnlyCrates": { "type": "array", "items": { "type": "string" } },
    "allowedGitDependencies": { "type": "array", "items": { "type": "string" } }
  }
}
