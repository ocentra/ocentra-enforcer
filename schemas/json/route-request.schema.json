{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ocentra.dev/schemas/ocentra-enforcer/route-request.schema.json",
  "title": "Ocentra Enforcer Route Request",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "root": { "type": "string" },
    "configPath": { "type": "string" },
    "profile": { "type": "string" },
    "scope": { "enum": ["workspace", "files", "crate", "diff"] },
    "files": { "type": "array", "items": { "type": "string" } },
    "languages": { "type": "array", "items": { "enum": ["rust", "typescript", "python", "common"] } },
    "crateName": { "type": "string" },
    "base": { "type": "string" },
    "head": { "type": "string" },
    "ruleId": { "type": "string" }
  }
}
