{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ocentra.dev/schemas/ocentra-enforcer/coordination-tool-arguments.schema.json",
  "title": "Ocentra Enforcer Coordination Tool Arguments",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "root": { "type": "string" },
    "stateRoot": { "type": "string" },
    "hub": { "type": "string" },
    "lane": { "type": "string" },
    "to": { "type": "string" },
    "body": { "type": "string" },
    "messageId": { "type": "string" },
    "paths": { "type": "array", "items": { "type": "string" } },
    "changedPaths": { "type": "array", "items": { "type": "string" } },
    "reason": { "type": "string" },
    "summary": { "type": "string" },
    "owner": { "type": "string" },
    "operation": {
      "type": "string",
      "enum": ["inspect", "edit", "commit", "push", "rebase", "merge", "pr_ready"]
    },
    "lockKind": {
      "type": "string",
      "enum": ["writeLock", "globalWriteLock", "branchLease", "workReservation"]
    },
    "onConflict": { "type": "string", "enum": ["fail", "intent"] },
    "claimGroup": { "type": "string" },
    "waitMs": { "type": "number" },
    "taskId": { "type": "string" },
    "state": { "type": "string" },
    "sessionId": { "type": "string" },
    "action": { "type": "string" },
    "peer": { "type": "string" },
    "peerUrl": { "type": "string" },
    "url": { "type": "string" },
    "name": { "type": "string" },
    "token": { "type": "string" },
    "tokenEnv": { "type": "string" },
    "mode": { "type": "string", "enum": ["pull", "push", "both"] },
    "host": { "type": "string" },
    "port": { "type": "number" },
    "keepLatest": { "type": "number" },
    "projectId": { "type": "string" },
    "repoRoot": { "type": "string" },
    "worktreeRoot": { "type": "string" },
    "cwd": { "type": "string" },
    "gitRemote": { "type": "string" },
    "branch": { "type": "string" },
    "commit": { "type": "string" },
    "codexThreadId": { "type": "string" },
    "codexSessionId": { "type": "string" },
    "stateFile": { "type": "string" },
    "peek": { "type": "boolean" },
    "dryRun": { "type": "boolean" },
    "write": { "type": "boolean" },
    "focused": { "type": "boolean" },
    "allowPrimaryWithoutClaims": { "type": "boolean" },
    "allowMergeRisks": { "type": "boolean" },
    "all": { "type": "boolean" },
    "limit": { "type": "number" }
  }
}
