{
  "schemaVersion": 2,
  "profileName": "ocentra-enforcer",
  "failOn": ["error"],
  "languages": ["rust", "typescript", "python", "common"],
  "requireCargoDeny": false,
  "requireCargoAudit": false,
  "runCargoDoc": false,
  "ignoreFileGlobs": [
    "db/**",
    "views/**",
    "Tools/**",
    "tools/**",
    "tests/enforcer-policy.test.mjs",
    "tests/rust-rules.test.mjs",
    "tests/enforcer-multilang.test.mjs",
    "tests/fixtures/enforcer/**",
    "profiles/*/legacy-scripts/**"
  ],
  "sourceShapePolicies": [
    {
      "roots": ["src", "scripts", "mcp"],
      "extensions": [".ts", ".tsx", ".js", ".mjs", ".cjs"],
      "kind": "typescript",
      "maxClasses": 1,
      "maxExports": 35,
      "maxFunctions": 30,
      "maxFunctionLines": 80,
      "maxLines": 1000
    }
  ],
  "rules": {},
  "waivers": [],
  "tools": {},
  "harness": {
    "store": "ndjson-duckdb",
    "storageDir": ".enforce",
    "maxArtifactBytes": 8000,
    "maxRuns": 50,
    "maxRunsPerTool": 20,
    "maxFailedRuns": 20,
    "pruneAfterDays": 14
  }
}
