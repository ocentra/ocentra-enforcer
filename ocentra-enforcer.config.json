      "extensions": [".ts", ".tsx", ".js", ".mjs", ".cjs"],
      "kind": "typescript",
      "maxClasses": 1,
      "maxExports": 35,
      "maxFunctions": 30,
      "maxFunctionLines": 80,
      "maxLines": 1000
    }
  ],
