{
  "name": "ocentra-enforcer",
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ocentra-enforcer": "./scripts/rust-rules.mjs",
    "ocentra-enforcer-mcp": "./mcp/rust-rules-mcp.mjs",
    "ocentra-enforcer-coordination": "./scripts/coordination.mjs",
    "rust-rules": "./scripts/rust-rules.mjs",
    "rust-rules-mcp": "./mcp/rust-rules-mcp.mjs",
    "ledger": "./scripts/coordination.mjs"
  },
  "exports": {
    "./eslint-rules": "./eslint-rules/index.js",
    "./eslint-rules/*": "./eslint-rules/*.js",
    "./rules": "./rules/rules.json"
  },
  "scripts": {
    "mcp:ocentra-enforcer": "node mcp/rust-rules-mcp.mjs",
    "mcp:rust-rules": "node mcp/rust-rules-mcp.mjs",
    "mcp:smoke": "node scripts/mcp-smoke.mjs --root . --profile strict --file Cargo.toml",
    "mcp:smoke:ndjson": "node scripts/mcp-smoke.mjs --root . --profile strict --file Cargo.toml --framing ndjson",
    "ci:local": "node scripts/ci-local.mjs",
    "codex:install:dry-run": "node scripts/rust-rules.mjs codex install --dry-run --root . --profile strict",
    "codex:doctor": "node scripts/rust-rules.mjs codex doctor --root . --profile strict",
    "enforcer:init:dry-run": "node scripts/rust-rules.mjs init --dry-run --root . --profile strict --adapters codex,mcp,precommit,github-actions",
    "enforcer:rules": "node scripts/rust-rules.mjs cargo --workspace",
    "enforcer:rules:scan": "node scripts/rust-rules.mjs scan --workspace",
    "enforcer:harness:smoke": "node scripts/rust-rules.mjs run --root . --tool node -- node --version",
    "coordination:smoke": "node scripts/rust-rules.mjs coordination root --hub ocentra-enforcer-smoke",
    "coordination:presence:smoke": "node scripts/rust-rules.mjs coordination presence --hub ocentra-enforcer-smoke",
    "coordination:manifest:smoke": "node scripts/rust-rules.mjs coordination manifest --hub ocentra-enforcer-smoke",
    "proof:smoke": "node scripts/rust-rules.mjs proof route --root . --files scripts/rust-rules.mjs --json",
    "proof:run:smoke": "node scripts/rust-rules.mjs proof run --root . --proof PROOF-COMMAND-GENERIC --run-id proof-command-smoke --json -- node --version",
    "architecture:smoke": "node scripts/rust-rules.mjs architecture check --language rust --scope files --files tests/fixtures/clean.rs --json",
    "validate:skill": "node scripts/validate-codex-assets.mjs --skill",
    "validate:plugin": "node scripts/validate-codex-assets.mjs --plugin",
    "validate:codex-assets": "node scripts/validate-codex-assets.mjs",
    "rust:rules": "node scripts/rust-rules.mjs cargo --workspace",
    "rust:rules:scan": "node scripts/rust-rules.mjs scan --workspace",
    "rust:rules:doctor": "node scripts/rust-rules.mjs doctor --workspace",
    "rust:rules:files": "node scripts/rust-rules.mjs scan --files",
    "rust:rules:crate": "node scripts/rust-rules.mjs cargo --crate",
    "test": "node --test tests/*.test.mjs",
    "test:multilang": "node --test tests/enforcer-multilang.test.mjs",
    "test:harness": "node --test tests/enforcer-harness.test.mjs",
    "test:mcp": "node --test tests/rust-rules-mcp.test.mjs",
    "test:rules": "node --test tests/rust-rules.test.mjs"
  },
  "dependencies": {
    "effect": "^3.21.4"
  }
}
